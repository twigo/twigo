{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:menu:default",
    "core:app:default",
    "core:window:allow-set-title",
    "core:webview:allow-set-webview-zoom",
    "opener:default",
    "dialog:allow-open",
    "store:default",
    "updater:default",
    "process:default"
  ]
}
